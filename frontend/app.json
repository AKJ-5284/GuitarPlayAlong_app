{
  "expo": {
    "name": "GuitarPlayAlong",
    "slug": "guitar-play-along",
    "version": "1.0.0",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.guitarplayalong.app"
    },
    "android": {
      "package": "com.guitarplayalong.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-file-system",
      "expo-audio",
      "expo-asset"
    ]
  }
}
